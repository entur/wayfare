# Runtime mode
# - dev: OMSA + Sales in dev, uses dev credentials
# - staging: OMSA + Sales in staging, uses staging credentials
# - local: OMSA on localhost, Sales in dev, uses dev credentials
# - local-tst: OMSA on localhost, Sales/OAuth/Audience use staging defaults, uses staging credentials
OMSA_ENV_MODE=dev

# Optional override for credential profile selection: dev | staging
# OMSA_CREDENTIAL_PROFILE=dev

# Optional endpoint overrides (leave unset to use mode defaults)
# OMSA_BASE_URL=
# SALES_BASE_URL=
# JOURNEY_PLANNER_URL=
# GEOCODER_URL=
# OAUTH_TOKEN_URL=
# AUTH0_AUDIENCE=

# OAuth Configuration

# Preferred credentials (profile based)
CLIENT_ID_DEV=
CLIENT_SECRET_DEV=
CLIENT_ID_STAGING=
CLIENT_SECRET_STAGING=

# Backward-compatible fallback credentials
# CLIENT_ID=
# CLIENT_SECRET=

# Entur Headers
ENTUR_DISTRIBUTION_CHANNEL=KOL:DistributionChannel:App
ET_CLIENT_NAME=omsa
ENTUR_POS=Kolumbus

# Server-side request/response logging in npm run dev terminal (true|false).
# Defaults to true in non-production when unset.
ENABLE_REQUEST_RESPONSE_LOGGING=true

# Logging detail level: meta | headers | body
# - meta: method/url/status/duration only
# - headers: meta + request/response headers
# - body: headers + request/response bodies (default)
REQUEST_RESPONSE_LOG_LEVEL=body

# Object print depth for logged payloads. Use full/null for unlimited depth, or a number like 2.
# Defaults to full depth when unset.
REQUEST_RESPONSE_LOG_DEPTH=full

# Redact sensitive headers (Authorization / Proxy-Authorization) in terminal logs.
# Defaults to true. Set to false only when you explicitly need raw values.
REQUEST_RESPONSE_LOG_REDACT_SENSITIVE_HEADERS=true
