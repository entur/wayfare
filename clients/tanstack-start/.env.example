# Runtime mode
# - dev: OMSA + Sales in dev, uses dev credentials
# - staging: OMSA + Sales in staging, uses staging credentials
# - local-dev: OMSA on localhost, Sales/OAuth/Audience use dev defaults
# - local-staging: OMSA on localhost, Sales/OAuth/Audience use staging defaults
OMSA_ENV_MODE=dev

# Per-env field hierarchy
# Every field below supports mode-specific prefixes. Resolution order, most specific first:
#   local-dev:     LOCAL_DEV_{FIELD} → DEV_{FIELD}     → {FIELD}
#   local-staging: LOCAL_STAGING_{FIELD} → STAGING_{FIELD} → {FIELD}
#   dev:           DEV_{FIELD} → {FIELD}
#   staging:       STAGING_{FIELD} → {FIELD}
#
# Examples:
#   STAGING_CLIENT_ID applies to both staging and local-staging (unless LOCAL_STAGING_CLIENT_ID is set).
#   CLIENT_ID is the universal fallback used when no prefixed value is found.

# Endpoint overrides (leave unset to use mode defaults)
# OMSA_BASE_URL=
# STAGING_OMSA_BASE_URL=
# LOCAL_STAGING_OMSA_BASE_URL=
# SALES_BASE_URL=
# JOURNEY_PLANNER_URL=
# GEOCODER_URL=
# OAUTH_TOKEN_URL=
# AUTH0_AUDIENCE=

# OAuth credentials
CLIENT_ID=
CLIENT_SECRET=
# STAGING_CLIENT_ID=
# STAGING_CLIENT_SECRET=

# Entur headers
ENTUR_DISTRIBUTION_CHANNEL=WAY:DistributionChannel:App
ENTUR_CLIENT_NAME=Wayfare-Web
ENTUR_POS=Wayfare
# STAGING_ENTUR_DISTRIBUTION_CHANNEL=
# STAGING_ENTUR_POS=

# Vipps
# VIPPS_PHONE_NUMBER=
# STAGING_VIPPS_PHONE_NUMBER=

# Server-side request/response logging in pnpm dev terminal (true|false).
# Defaults to true in non-production when unset.
ENABLE_REQUEST_RESPONSE_LOGGING=true

# Logging detail level: meta | headers | body
# - meta: method/url/status/duration only
# - headers: meta + request/response headers
# - body: headers + request/response bodies
# Defaults to body when unset.
REQUEST_RESPONSE_LOG_LEVEL=body

# Object print depth for logged payloads. Use full/null for unlimited depth, or a number like 2.
# Defaults to full depth when unset.
REQUEST_RESPONSE_LOG_DEPTH=full

# Redact sensitive headers (Authorization / Proxy-Authorization) in terminal logs.
# Defaults to true. Set to false only when you explicitly need raw values.
REQUEST_RESPONSE_LOG_REDACT_SENSITIVE_HEADERS=true
